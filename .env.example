# Copy to `.env` and fill in. `.env` is gitignored — never commit real tokens.
#
# Hugging Face token for an account that has access to the gated TabPFN repo
# (Prior-Labs/tabpfn_3). It is used to download the model checkpoint, which is
# then passed to TabPFNRegressor via `model_path`. Providing `model_path`
# bypasses TabPFN's PriorLabs license gate, so NO separate TABPFN_TOKEN is
# needed for local differentiable inference.
#
# Get a token at https://huggingface.co/settings/tokens (a read token is enough),
# and make sure that account has accepted access to Prior-Labs/tabpfn_3.
HF_TOKEN=hf_your_token_here
